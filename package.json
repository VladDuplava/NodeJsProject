{
  "name": "library-rental-api",
  "version": "2.1.0",
  "description": "API для оренди книг у бібліотеці (MySQL + Swagger)",
  "main": "app.js",
  "scripts": {
    "start": "node bin/www",
    "dev": "../node_modules/.bin/nodemon NodeJsProject/bin/www",
    "seed": "node config/seed.js",
    "test": "../node_modules/.bin/jest --config jest.config.js --runInBand --forceExit",
    "test:watch": "../node_modules/.bin/jest --config jest.config.js --watch --runInBand",
    "test:coverage": "../node_modules/.bin/jest --config jest.config.js --coverage --runInBand --forceExit",
    "lint": "../node_modules/.bin/eslint .",
    "lint:fix": "../node_modules/.bin/eslint . --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "sequelize": "^6.37.3",
    "mysql2": "^3.9.7",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "sequelize-mock": "^0.10.2"
  }
}
